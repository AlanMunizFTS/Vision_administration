DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change_me

SYNC_BASE_SYNC_DIR=
SYNC_RETENTION_ENABLED=true
SYNC_RETENTION_DAYS=7
SYNC_RETENTION_FOLDER_PREFIX=Database_
SYNC_RETENTION_DATE_FORMAT=ddMMyy

SYNC_SSH_USER=remote_user
SYNC_SSH_BATCH_MODE=true
SYNC_SSH_CONNECT_TIMEOUT_SECONDS=20
SYNC_SSH_REMOTE_COMMAND=

SYNC_POSTGRES_DOCKER_CONTAINER=
SYNC_POSTGRES_DATABASE=
SYNC_POSTGRES_USER=
SYNC_POSTGRES_TARGET_TABLE=
SYNC_POSTGRES_SOURCE_STATION_COLUMN=

# Format: name|ip|output_file|enabled;name|ip|output_file|enabled
SYNC_STATIONS=
