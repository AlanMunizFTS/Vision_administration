DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=vision_administration
DB_USER=vision_admin
DB_PASSWORD=vision_admin_dev
RUN_MIGRATIONS=true

SYNC_BASE_SYNC_DIR=
SYNC_EXPORT_RETRIES=2
SYNC_EXPORT_RETRY_DELAY_SECONDS=5
SYNC_FETCH_RETRIES=3
SYNC_FETCH_RETRY_DELAY_SECONDS=5
SYNC_STATION_RETRIES=1
SYNC_STATION_RETRY_DELAY_SECONDS=10

SYNC_SSH_USER=remote_user
SYNC_SSH_BATCH_MODE=true
SYNC_SSH_CONNECT_TIMEOUT_SECONDS=20
SYNC_SSH_STRICT_HOST_KEY_CHECKING=
SYNC_SSH_USER_KNOWN_HOSTS_FILE=
SYNC_SSH_BOOTSTRAP_KEYS=true
SYNC_SSH_KEY_TYPE=ed25519
SYNC_SSH_KEY_COMMENT=vision-sync
SYNC_SSH_KEY_PATH=
SYNC_SSH_PUBLIC_KEY_PATH=
SYNC_SSH_COPY_PASSWORD=
SYNC_SSH_AUTHORIZED_KEYS_MODE=windows_admin
SYNC_SSH_REMOTE_COMMAND=
SYNC_SSH_REMOTE_OUTPUT_DIR=
SYNC_SSH_REMOTE_OUTPUT_STATIONS=

SYNC_POSTGRES_DOCKER_CONTAINER=vision_administration_db
SYNC_POSTGRES_HOST=
SYNC_POSTGRES_PORT=
SYNC_POSTGRES_DATABASE=vision_administration
SYNC_POSTGRES_USER=vision_admin
SYNC_POSTGRES_PASSWORD=
SYNC_POSTGRES_TARGET_TABLE=
SYNC_POSTGRES_SOURCE_STATION_COLUMN=

# Format: name|ip|output_file|enabled;name|ip|output_file|enabled
SYNC_STATIONS=
